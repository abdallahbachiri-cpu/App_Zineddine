default_platform(:ios)

platform :ios do
  desc "Copy generated golden tests to Fastlane screenshots directory"
  lane :prepare_screenshots do
    require 'fileutils'
    
    fastlane_dir = File.dirname(__FILE__)
    ios_dir = File.expand_path("..", fastlane_dir)
    project_root = File.expand_path("..", ios_dir)
    
    out_dir = File.join(fastlane_dir, "screenshots", "en-US")
    FileUtils.mkdir_p(out_dir)
    
    goldens_dir = File.join(project_root, "test", "goldens", "goldens")
    
    # 1. Copy phone screenshots (e.g. iPhone 11 rendering) to APP_IPHONE_65 (typical for Pro Max/11 Pro Max size)
    phone_images = Dir.glob(File.join(goldens_dir, "*_iphone11.png"))
    phone_images.each do |file|
      filename = File.basename(file)
      FileUtils.cp(file, File.join(out_dir, "APP_IPHONE_65_#{filename}"))
    end
    
    # 2. Copy tablet screenshots
    tablet_images = Dir.glob(File.join(goldens_dir, "*_tabletPortrait.png"))
    tablet_images.each do |file|
      filename = File.basename(file)
      FileUtils.cp(file, File.join(out_dir, "APP_IPAD_PRO_3GEN_129_#{filename}"))
    end
    
    UI.success("iOS Screenshots generated by Golden tests successfully staged for Fastlane. Copied #{phone_images.length + tablet_images.length} images.")
  end

  desc "Upload screenshots and metadata to App Store Connect"
  lane :upload_store_screenshots do
    prepare_screenshots
    
    # deliver is the action that interacts with App Store Connect
    deliver(
      skip_metadata: true,
      skip_app_version_update: true,
      skip_screenshots: false,
      submit_for_review: false,
      automatic_release: false
    )
  end
  
  desc "Full Deployment (Build IPA, upload everything)"
  lane :deploy do
    prepare_screenshots
    build_app(workspace: "Runner.xcworkspace", scheme: "Runner")
    upload_to_testflight
    deliver(submit_for_review: true)
  end
end
